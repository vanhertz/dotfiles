# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.config/zsh/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# source external files
[[ -r $XDG_CONFIG_HOME/shell/.zaliases ]] && source $XDG_CONFIG_HOME/shell/.zaliases

# Created by newuser for 5.9.1
source ~/.powerlevel10k/powerlevel10k.zsh-theme

# tab autocompletions
autoload -Uz compinit
zstyle ':completion:*' menu select
zmodload zsh/complist
_comp_options+=(globdots)
compinit -d $XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION

# history
export HISTSIZE=200         # number of commands to remember in the command history
export SAVEHIST=2000      # number of commands to save in the history file
export HISTFILE="$HOME/.cache/zsh/history"
setopt hist_ignore_dups     # do not record an event that was just recorded again
setopt hist_ignore_all_dups # delete an old recorded event if a new event is a duplicate
setopt hist_ignore_space    # do not record an event starting with a space
setopt hist_save_no_dups    # do not write a duplicate event to the history file
setopt inc_append_history   # write to the history file immediately, not when the shell exits
setopt share_history        # share history between terminals

# Tratar puntos y barras como lĂ­mites al moverse o borrar palabras.
WORDCHARS=${WORDCHARS//[.\/]/}

# fix vi plugin conflicting with fzf
export ZVM_INIT_MODE=sourcing

# --- CONFIGURACIĂ“N DE TECLAS (COMPATIBLE CON ZSH-VI-MODE) ---
zmodload zsh/terminfo

function select-word-left() {
  if (( ! REGION_ACTIVE )); then
    MARK=$CURSOR
    REGION_ACTIVE=1
  fi
  zle backward-word
}

function select-word-right() {
  if (( ! REGION_ACTIVE )); then
    MARK=$CURSOR
    REGION_ACTIVE=1
  fi
  zle forward-word
}

function select-char-left() {
  if (( ! REGION_ACTIVE )); then
    MARK=$CURSOR
    REGION_ACTIVE=1
  fi
  zle backward-char
}

function select-char-right() {
  if (( ! REGION_ACTIVE )); then
    MARK=$CURSOR
    REGION_ACTIVE=1
  fi
  zle forward-char
}

function move-char-left() {
  REGION_ACTIVE=0
  zle backward-char
}

function move-char-right() {
  REGION_ACTIVE=0
  zle forward-char
}

function move-word-left() {
  REGION_ACTIVE=0
  zle backward-word
}

function move-word-right() {
  REGION_ACTIVE=0
  zle forward-word
}

function delete-selection-or-char() {
  if (( REGION_ACTIVE )); then
    zle kill-region
    REGION_ACTIVE=0
  else
    zle delete-char
  fi
}

function copy-selection-to-clipboard() {
  if (( REGION_ACTIVE )); then
    local start=$MARK
    local end=$CURSOR
    local swap selected

    if (( start > end )); then
      swap=$start
      start=$end
      end=$swap
    fi

    selected=${BUFFER[$(( start + 1 )),$end]}

    if (( $+commands[wl-copy] )); then
      print -rn -- "$selected" | wl-copy >/dev/null 2>&1
    else
      zle -M 'Falta instalar wl-copy'
    fi
  fi
}

function setup-keybindings() {
  local keymap
  local left=${terminfo[kcub1]:-$'\e[D'}
  local right=${terminfo[kcuf1]:-$'\e[C'}
  local shift_left=${terminfo[kLFT]:-$'\e[1;2D'}
  local shift_right=${terminfo[kRIT]:-$'\e[1;2C'}
  local ctrl_left=${terminfo[kLFT5]:-$'\e[1;5D'}
  local ctrl_right=${terminfo[kRIT5]:-$'\e[1;5C'}
  local ctrl_shift_left=${terminfo[kLFT6]:-$'\e[1;6D'}
  local ctrl_shift_right=${terminfo[kRIT6]:-$'\e[1;6C'}
  local insert=${terminfo[kich1]:-$'\e[2~'}
  local delete=${terminfo[kdch1]:-$'\e[3~'}
  local ctrl_delete=${terminfo[kDC5]:-$'\e[3;5~'}
  local copy_selection=$'\x18c'

  zle -N select-word-left
  zle -N select-word-right
  zle -N select-char-left
  zle -N select-char-right
  zle -N move-char-left
  zle -N move-char-right
  zle -N move-word-left
  zle -N move-word-right
  zle -N delete-selection-or-char
  zle -N copy-selection-to-clipboard

  # Resaltar la regiĂłn seleccionada con los colores Catppuccin del terminal.
  zle_highlight=(${zle_highlight:#region:*} 'region:fg=#1e1e2e,bg=#f5e0dc')

  # Mantener la ediciĂłn normal incluso si zsh-vi-mode cambia el mapa activo.
  bindkey -e
  for keymap in emacs viins; do
    bindkey -M $keymap "$left" move-char-left
    bindkey -M $keymap "$right" move-char-right
    bindkey -M $keymap $'\e[D' move-char-left
    bindkey -M $keymap $'\e[C' move-char-right
    bindkey -M $keymap $'\eOD' move-char-left
    bindkey -M $keymap $'\eOC' move-char-right
    bindkey -M $keymap "$shift_left" select-char-left
    bindkey -M $keymap "$shift_right" select-char-right
    bindkey -M $keymap "$ctrl_left" move-word-left
    bindkey -M $keymap "$ctrl_right" move-word-right
    bindkey -M $keymap "$ctrl_shift_left" select-word-left
    bindkey -M $keymap "$ctrl_shift_right" select-word-right

    bindkey -M $keymap '^H' backward-kill-word
    bindkey -M $keymap "$ctrl_delete" kill-word
    bindkey -M $keymap "$delete" delete-selection-or-char
    bindkey -M $keymap "$insert" overwrite-mode
    bindkey -M $keymap "$copy_selection" copy-selection-to-clipboard
    bindkey -M $keymap '^C' send-break

    bindkey -M $keymap '^[[H' beginning-of-line
    bindkey -M $keymap '^[[F' end-of-line
    bindkey -M $keymap '^[[1~' beginning-of-line
    bindkey -M $keymap '^[[4~' end-of-line

    bindkey -M $keymap -s '^[[5~' ''
    bindkey -M $keymap -s '^[[6~' ''
  done
}

# Integrar los widgets personalizados con zsh-autosuggestions.
ZSH_AUTOSUGGEST_ACCEPT_WIDGETS+=(move-char-right)
ZSH_AUTOSUGGEST_PARTIAL_ACCEPT_WIDGETS+=(move-word-right)
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(delete-selection-or-char)
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(copy-selection-to-clipboard)

# zsh-vi-mode invoca este hook al terminar su inicializaciĂłn.
function zvm_after_init() {
  setup-keybindings
}

# basic plugin manager to automatically import zsh plugins
# script by mattmc3 from https://github.com/mattmc3/zsh_unplugged
# clone a plugin, identify its init file, source it, and add it to your fpath
function plugin-load {
	local repo plugdir initfile initfiles=()
	: ${ZPLUGINDIR:=${ZDOTDIR:-~/.config/zsh}/plugins}
	for repo in $@; do
		plugdir=$ZPLUGINDIR/${repo:t}
		initfile=$plugdir/${repo:t}.plugin.zsh
		if [[ ! -d $plugdir ]]; then
			echo "Cloning $repo..."
			git clone -q --depth 1 --recursive --shallow-submodules \
				https://github.com/$repo $plugdir
		fi
		if [[ ! -e $initfile ]]; then
			initfiles=($plugdir/*.{plugin.zsh,zsh-theme,zsh,sh}(N))
			(( $#initfiles )) || { echo >&2 "No init file '$repo'." && continue }
			ln -sf $initfiles[1] $initfile
		fi
		fpath+=$plugdir
		(( $+functions[zsh-defer] )) && zsh-defer . $initfile || . $initfile
	done
}

# list of github repos of plugins
repos=(
	romkatv/powerlevel10k

	skywind3000/z.lua
	jeffreytse/zsh-vi-mode

	romkatv/zsh-defer
	zsh-users/zsh-autosuggestions
	zdharma-continuum/fast-syntax-highlighting
	kazhala/dotbare
)
plugin-load $repos

# plugin options
export DOTBARE_DIR="$HOME/.dotfiles"
export DOTBARE_TREE="$HOME"
export MAGIC_ENTER_OTHER_COMMAND='ls -a .'

# fzf in terminal, fzf must be installed to use this
(( $+commands[fzf] )) && eval "$(fzf --zsh)"
# fzf catppuccin theme
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

# Reaplicar despuĂ©s de fzf para que ningĂşn plugin sustituya estos bindings.
setup-keybindings

# To customize prompt, run `p10k configure` or edit ~/.config/zsh/.p10k.zsh.
[[ ! -f ~/.config/zsh/.p10k.zsh ]] || source ~/.config/zsh/.p10k.zsh
